---
import { ExternalLink } from "../external-link";
import styles from "./styles.module.css";

type Props = {
  path: string;
  text: string;
};

const { path, text } = Astro.props;

const _prefix = "https://developer.mozilla.org/en-US/docs/";
---

<blockquote class={styles.container} cite={_prefix + path}>
  <p class={styles.main}>
    <slot />
  </p>
  <footer>
    <ExternalLink href={_prefix + path}>mdn » {text}</ExternalLink>
  </footer>
</blockquote>
